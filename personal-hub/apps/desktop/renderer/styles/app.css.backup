/* Reset & Base */
:root {
  --bg-primary: #0f1115;
  --bg-secondary: #161920;
  --bg-tertiary: #1e222b;
  --bg-hover: rgba(255, 255, 255, 0.05);
  
  --text-primary: #f8fafc;
  --text-secondary: #94a3b8;
  --text-tertiary: #64748b;
  
  --accent-primary: #6366f1;
  --accent-secondary: #8b5cf6;
  --accent-gradient: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);
  --accent-glow: rgba(99, 102, 241, 0.15);
  
  --status-success: #10b981;
  --status-error: #ef4444;
  --status-warning: #f59e0b;
  
  --border-default: rgba(255, 255, 255, 0.08);
  --border-light: rgba(255, 255, 255, 0.04);
  
  --radius-sm: 6px;
  --radius-md: 12px;
  --radius-lg: 18px;
  --radius-full: 9999px;
  
  --shadow-sm: 0 1px 3px 0 rgba(0, 0, 0, 0.1);
  --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
  --shadow-lg: 0 20px 25px -5px rgba(0, 0, 0, 0.2);
  
  --transition-fast: 150ms cubic-bezier(0.4, 0, 0.2, 1);
  --transition-default: 250ms cubic-bezier(0.4, 0, 0.2, 1);
}

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  -webkit-font-smoothing: antialiased;
}

body {
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  background-color: var(--bg-primary);
  color: var(--text-primary);
  overflow: hidden;
  line-height: 1.5;
}

#root {
  width: 100vw;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

/* Title Bar */
.titlebar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 38px;
  background-color: var(--bg-primary);
  border-bottom: 1px solid var(--border-default);
  color: var(--text-secondary);
  user-select: none;
  -webkit-user-select: none;
  flex-shrink: 0;
  z-index: 1000;
}

.titlebar-drag {
  flex: 1;
  display: flex;
  align-items: center;
  height: 100%;
  -webkit-app-region: drag;
  padding-left: 16px;
}

.titlebar-title {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: var(--text-tertiary);
}

.titlebar-controls {
  display: flex;
  height: 100%;
  -webkit-app-region: no-drag;
}

.titlebar-button {
  width: 46px;
  height: 100%;
  border: none;
  background: transparent;
  color: var(--text-tertiary);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--transition-fast);
}

.titlebar-button:hover {
  background-color: var(--bg-hover);
  color: var(--text-primary);
}

.titlebar-button.titlebar-close:hover {
  background-color: var(--status-error);
  color: #ffffff;
}

/* Sidebar */
.sidebar {
  width: 260px;
  background-color: var(--bg-secondary);
  border-right: 1px solid var(--border-default);
  display: flex;
  flex-direction: column;
  height: calc(100vh - 38px);
}

.sidebar-header {
  padding: 24px 20px;
  border-bottom: 1px solid var(--border-light);
}

.sidebar-title {
  font-size: 18px;
  font-weight: 700;
  background: var(--accent-gradient);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  margin-bottom: 4px;
}
  color: #ffffff;
  margin-bottom: 8px;
}

.offline-indicator {
  display: inline-block;
  padding: 2px 8px;
  background-color: var(--status-error);
  color: white;
  border-radius: var(--radius-full);
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.sidebar-nav {
  flex: 1;
  padding: 16px 12px;
  overflow-y: auto;
}

.sidebar-item {
  display: flex;
  align-items: center;
  gap: 12px;
  width: 100%;
  padding: 10px 14px;
  background: transparent;
  border: none;
  color: var(--text-secondary);
  cursor: pointer;
  border-radius: var(--radius-md);
  font-size: 14px;
  font-weight: 500;
  transition: all var(--transition-fast);
  margin-bottom: 4px;
  text-align: left;
}

.sidebar-item:hover {
  background-color: var(--bg-hover);
  color: var(--text-primary);
  transform: translateX(4px);
}

.sidebar-item.active {
  background-color: var(--bg-tertiary);
  color: var(--accent-primary);
  box-shadow: var(--shadow-sm);
}

.sidebar-item.active .sidebar-icon {
  color: var(--accent-primary);
}

.sidebar-icon {
  font-size: 18px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-tertiary);
  transition: color var(--transition-fast);
}

/* Workspace */
.workspace {
  flex: 1;
  display: flex;
  flex-direction: column;
  background-color: var(--bg-primary);
  height: calc(100vh - 38px);
  overflow: hidden;
}

.offline-banner {
  background-color: var(--status-warning);
  color: #000;
  padding: 8px 20px;
  text-align: center;
  font-size: 12px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  z-index: 100;
}

.workspace-content {
  flex: 1;
  overflow-y: auto;
  position: relative;
}

/* Topbar */
.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20px 32px;
  background-color: var(--bg-primary);
  border-bottom: 1px solid var(--border-default);
}

.topbar-title {
  font-size: 24px;
  font-weight: 700;
  letter-spacing: -0.02em;
  color: var(--text-primary);
}

.topbar-actions {
  display: flex;
  gap: 12px;
}

/* Page Transitions */
.page-fade-enter {
  opacity: 0;
  transform: translateY(10px);
}
.page-fade-enter-active {
  opacity: 1;
  transform: translateY(0);
  transition: opacity var(--transition-default), transform var(--transition-default);
}

/* Page Layout */
.page {
  display: flex;
  flex-direction: column;
  height: 100%;
  animation: pageSlideIn var(--transition-default);
}

@keyframes pageSlideIn {
  from { opacity: 0; transform: translateY(8px); }
  to { opacity: 1; transform: translateY(0); }
}

.page-content {
  flex: 1;
  padding: 32px;
  overflow-y: auto;
}

/* Login */
.login-container {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100vw;
  height: calc(100vh - 38px);
  background: radial-gradient(circle at top right, var(--bg-tertiary), var(--bg-primary));
}

.login-box {
  width: 100%;
  max-width: 400px;
  padding: 48px;
  background-color: var(--bg-secondary);
  border-radius: var(--radius-lg);
  border: 1px solid var(--border-default);
  box-shadow: var(--shadow-lg);
}

.login-title {
  font-size: 32px;
  font-weight: 800;
  margin-bottom: 8px;
  text-align: center;
  letter-spacing: -0.03em;
}

.login-subtitle {
  font-size: 15px;
  color: var(--text-tertiary);
  margin-bottom: 40px;
  text-align: center;
}

/* Forms */
.form-group {
  display: flex;
  flex-direction: column;
  gap: 8px;
  margin-bottom: 24px;
}

.form-group label {
  font-size: 14px;
  font-weight: 600;
  color: var(--text-secondary);
  margin-left: 4px;
}

input[type="text"],
input[type="password"],
input[type="email"],
textarea {
  width: 100%;
  padding: 12px 16px;
  background-color: var(--bg-primary);
  border: 1px solid var(--border-default);
  border-radius: var(--radius-md);
  color: var(--text-primary);
  font-size: 15px;
  transition: all var(--transition-fast);
}

input:focus {
  outline: none;
  border-color: var(--accent-primary);
  box-shadow: 0 0 0 4px var(--accent-glow);
}

/* Buttons */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 10px 20px;
  border-radius: var(--radius-md);
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  transition: all var(--transition-fast);
  border: 1px solid transparent;
}

.btn-primary {
  background: var(--accent-gradient);
  color: white;
  box-shadow: 0 4px 12px rgba(99, 102, 241, 0.3);
}

.btn-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 16px rgba(99, 102, 241, 0.4);
}

.btn-secondary {
  background-color: var(--bg-tertiary);
  color: var(--text-primary);
  border-color: var(--border-default);
}

.btn-secondary:hover {
  background-color: var(--bg-hover);
}

/* Tool Grid & Cards */
.tool-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 24px;
}

.tool-card {
  background-color: var(--bg-secondary);
  border-radius: var(--radius-lg);
  border: 1px solid var(--border-default);
  padding: 24px;
  transition: all var(--transition-default);
  cursor: pointer;
  position: relative;
  overflow: hidden;
}

.tool-card:hover {
  transform: translateY(-4px);
  border-color: var(--accent-primary);
  box-shadow: var(--shadow-lg);
}

.tool-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4px;
  background: var(--accent-gradient);
  opacity: 0;
  transition: opacity var(--transition-fast);
}

.tool-card:hover::before {
  opacity: 1;
}

/* Skeleton Loader */
.skeleton {
  background: linear-gradient(90deg, var(--bg-tertiary) 25%, var(--bg-hover) 50%, var(--bg-tertiary) 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s infinite;
  border-radius: var(--radius-md);
}

@keyframes skeleton-loading {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* Hero Section */
.hero {
  padding: 40px;
  background: var(--bg-secondary);
  border-radius: var(--radius-lg);
  border: 1px solid var(--border-default);
  margin-bottom: 32px;
  position: relative;
  overflow: hidden;
}

.hero-content {
  position: relative;
  z-index: 1;
}

.hero-title {
  font-size: 36px;
  font-weight: 800;
  margin-bottom: 12px;
  letter-spacing: -0.04em;
}

.hero-subtitle {
  font-size: 16px;
  color: var(--text-secondary);
  max-width: 500px;
}
.form-group input[type="password"],
.form-group select {
  padding: 12px 14px;
  background-color: #1e1e1e;
  border: 1px solid #1e1e1e;
  border-radius: 4px;
  color: #dcddde;
  font-size: 14px;
  transition: all 0.2s ease;
}

.form-group input:focus,
.form-group select:focus {
  outline: none;
  border-color: #4a90e2;
  background-color: #202020;
}

.form-group input:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

/* Buttons */
.btn-primary,
.btn-secondary {
  padding: 12px 24px;
  border: none;
  border-radius: 4px;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.15s ease;
}

.btn-primary {
  background-color: #5865f2;
  color: #ffffff;
}

.btn-primary:hover:not(:disabled) {
  background-color: #4752c4;
  box-shadow: 0 2px 8px rgba(88, 101, 242, 0.3);
}

.btn-primary:active:not(:disabled) {
  background-color: #3c45a5;
}

.btn-primary:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.btn-secondary {
  background-color: #4e5058;
  color: #ffffff;
  border: none;
}

.btn-secondary:hover {
  background-color: #5d5f67;
}

.btn-upgrade {
  padding: 8px 16px;
  background-color: #ff9800;
  color: #000;
  border: none;
  border-radius: 6px;
  font-weight: 600;
  cursor: pointer;
  margin-top: 8px;
}

/* Cards */
.card {
  background-color: #2a2a2a;
  border: 1px solid #1e1e1e;
  border-radius: 8px;
  padding: 20px;
  margin-bottom: 20px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
}

.card h3 {
  font-size: 18px;
  margin-bottom: 16px;
  color: #ffffff;
}

/* Dashboard */
.dashboard-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 20px;
}

.status-list,
.info-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.status-item,
.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 0;
  color: #b0b0b0;
}

.status-online {
  color: #4caf50;
  font-weight: 600;
}

.status-offline {
  color: #f44336;
  font-weight: 600;
}

.status-success {
  color: #4caf50;
}

.status-disabled {
  color: #808080;
}

/* Activity */
.activity-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
  max-height: 300px;
  overflow-y: auto;
}

.activity-item {
  display: flex;
  justify-content: space-between;
  padding: 10px 14px;
  background-color: #2a2a2a;
  border-radius: 4px;
  font-size: 13px;
  transition: background-color 0.15s ease;
}

.activity-item:hover {
  background-color: #2f2f2f;
}

.activity-type {
  color: #b0b0b0;
}

.activity-time {
  color: #808080;
  font-size: 12px;
}

/* Quick Actions */
.quick-actions {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

/* Tools */
.tools-header {
  margin-bottom: 24px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.tools-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 20px;
}

/* Tool Card */
.tool-card {
  background-color: #2a2a2a;
  border: 1px solid #1e1e1e;
  border-radius: 8px;
  padding: 20px;
  transition: all 0.2s ease;
  position: relative;
  box-shadow: 0 2px 6px rgba(0, 0, 0, 0.2);
}

.tool-card:not(.locked):hover {
  border-color: #4a90e2;
  transform: translateY(-3px);
  box-shadow: 0 6px 16px rgba(74, 144, 226, 0.15);
}

.tool-card.locked {
  opacity: 0.6;
}

.tool-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12px;
}

.tool-icon {
  font-size: 32px;
}

.premium-badge,
.lock-icon {
  font-size: 14px;
  padding: 4px 8px;
  background-color: #ff9800;
  color: #000;
  border-radius: 4px;
  font-weight: 600;
}

.lock-icon {
  background-color: #f44336;
  color: white;
}

.tool-name {
  font-size: 18px;
  font-weight: 600;
  margin-bottom: 8px;
  color: #ffffff;
}

.tool-description {
  font-size: 14px;
  color: #b0b0b0;
  margin-bottom: 12px;
  line-height: 1.5;
}

.tool-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-bottom: 8px;
}

.tool-tag {
  padding: 4px 8px;
  background-color: #2d2d2d;
  border-radius: 4px;
  font-size: 12px;
  color: #808080;
}

.tool-warning {
  margin-top: 8px;
  padding: 8px;
  background-color: #f443361a;
  border-left: 3px solid #f44336;
  font-size: 12px;
  color: #f44336;
  border-radius: 4px;
}

/* Search */
.search-bar {
  width: 100%;
}

.search-input {
  width: 100%;
  padding: 12px 16px;
  background-color: #1e1e1e;
  border: 1px solid #1e1e1e;
  border-radius: 4px;
  color: #dcddde;
  font-size: 14px;
  transition: all 0.2s ease;
}

.search-input:focus {
  outline: none;
  border-color: #5865f2;
  background-color: #202020;
}

.search-input::placeholder {
  color: #6a6a6a;
}

/* Tag Filter */
.tag-filter {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.tag-chip {
  padding: 8px 16px;
  background-color: #2a2a2a;
  border: 1px solid #1e1e1e;
  border-radius: 16px;
  color: #949494;
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.15s ease;
}

.tag-chip:hover {
  background-color: #2f2f2f;
  border-color: #5865f2;
  color: #dcddde;
}

.tag-chip.active {
  background-color: #5865f2;
  border-color: #5865f2;
  color: #ffffff;
}

/* Profile */
.profile-section {
  margin-bottom: 32px;
}

.profile-section h3 {
  font-size: 18px;
  margin-bottom: 16px;
  color: #ffffff;
}

.permissions-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 12px;
}

.permission-item label {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 14px;
  background-color: #2a2a2a;
  border: 1px solid #1e1e1e;
  border-radius: 6px;
  cursor: pointer;
  transition: all 0.15s ease;
}

.permission-item label:hover {
  background-color: #2f2f2f;
  border-color: #5865f2;
}

/* Custom Checkbox Styling */
input[type="checkbox"] {
  -webkit-appearance: none;
  appearance: none;
  width: 20px;
  height: 20px;
  border: 2px solid #4a4a4a;
  border-radius: 4px;
  background-color: #2d2d2d;
  cursor: pointer;
  position: relative;
  transition: all 0.2s ease;
  flex-shrink: 0;
}

input[type="checkbox"]:hover {
  border-color: #4a90e2;
}

input[type="checkbox"]:checked {
  background-color: #4a90e2;
  border-color: #4a90e2;
}

input[type="checkbox"]:checked::after {
  content: '';
  position: absolute;
  left: 5px;
  top: 2px;
  width: 5px;
  height: 9px;
  border: solid white;
  border-width: 0 2px 2px 0;
  transform: rotate(45deg);
}

input[type="checkbox"]:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.permission-item input[type="checkbox"] {
  margin: 0;
}

/* Settings */
.settings-section {
  margin-bottom: 32px;
}

.settings-section h3 {
  font-size: 18px;
  margin-bottom: 16px;
  color: #ffffff;
}

.setting-item {
  padding: 14px;
  background-color: #2a2a2a;
  border: 1px solid #1e1e1e;
  border-radius: 6px;
  margin-bottom: 8px;
  transition: background-color 0.15s ease;
}

.setting-item:hover {
  background-color: #2f2f2f;
}

.setting-item label {
  display: flex;
  align-items: center;
  gap: 10px;
  cursor: pointer;
}

/* Logs */
.log-viewer {
  background-color: #2a2a2a;
  border: 1px solid #1e1e1e;
  border-radius: 8px;
  padding: 16px;
  box-shadow: 0 2px 6px rgba(0, 0, 0, 0.2);
}

.log-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
  font-weight: 600;
}

.log-list {
  max-height: 400px;
  overflow-y: auto;
}

.log-entry {
  display: grid;
  grid-template-columns: auto 1fr auto auto;
  gap: 12px;
  padding: 10px 14px;
  background-color: #1e1e1e;
  border-radius: 4px;
  margin-bottom: 4px;
  font-size: 13px;
  align-items: center;
  transition: background-color 0.15s ease;
}

.log-entry:hover {
  background-color: #252525;
}

.log-time {
  color: #808080;
  font-size: 12px;
}

.log-type {
  color: #b0b0b0;
}

.log-tool {
  color: #4a90e2;
  font-size: 12px;
}

.log-status {
  padding: 2px 6px;
  border-radius: 4px;
  font-size: 11px;
  font-weight: 600;
}

.log-status.status-success {
  background-color: #4caf5033;
  color: #4caf50;
}

.log-status.status-error {
  background-color: #f4433633;
  color: #f44336;
}

.log-status.status-blocked {
  background-color: #ff980033;
  color: #ff9800;
}

/* Empty State */
.empty-state {
  text-align: center;
  padding: 60px 20px;
  color: #808080;
  font-size: 16px;
}

/* Offline Message */
.offline-message {
  text-align: center;
  padding: 40px;
  max-width: 600px;
  margin: 0 auto;
}

.offline-message h2 {
  font-size: 24px;
  margin-bottom: 20px;
}

.offline-message ul {
  text-align: left;
  margin: 16px 0;
  padding-left: 40px;
}

.offline-message li {
  margin: 8px 0;
  color: #b0b0b0;
}

/* Error Message */
.error-message {
  padding: 12px;
  background-color: #f4433633;
  border: 1px solid #f44336;
  border-radius: 6px;
  color: #f44336;
  font-size: 14px;
}

/* Permission Denied */
.permission-denied {
  padding: 20px;
  text-align: center;
  color: #f44336;
  background-color: #f4433633;
  border-radius: 8px;
}

/* Scrollbar */
::-webkit-scrollbar {
  width: 8px;
  height: 8px;
}

::-webkit-scrollbar-track {
  background: #1a1a1a;
}

::-webkit-scrollbar-thumb {
  background: #4a4a4a;
  border-radius: 4px;
}

::-webkit-scrollbar-thumb:hover {
  background: #5a5a5a;
}

/* Loading Spinner */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background-color: rgba(30, 30, 30, 0.95);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
  animation: fadeIn 0.3s ease;
}

.loading-spinner {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20px;
}

.loading-spinner p {
  color: #dcddde;
  font-size: 16px;
  font-weight: 500;
}

.spinner {
  width: 50px;
  height: 50px;
  border: 3px solid #2a2a2a;
  border-top-color: #5865f2;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.loading-spinner-inline {
  display: flex;
  justify-content: center;
  padding: 20px;
}

.spinner-small {
  width: 24px;
  height: 24px;
  border: 2px solid #2a2a2a;
  border-top-color: #5865f2;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

/* Animations */
@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@keyframes fadeOut {
  from {
    opacity: 1;
  }
  to {
    opacity: 0;
  }
}

@keyframes slideInFromBottom {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes slideInFromRight {
  from {
    opacity: 0;
    transform: translateX(20px);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

/* Page Transitions */
.page-fade-enter {
  animation: fadeIn 0.3s ease;
}

.page-slide-enter {
  animation: slideInFromBottom 0.4s ease;
}

/* Login Box Animation */
.login-box {
  animation: slideInFromBottom 0.5s ease;
}

/* Sidebar Items Animation */
.sidebar-item {
  animation: slideInFromRight 0.3s ease;
}

.sidebar-item:nth-child(1) { animation-delay: 0.05s; }
.sidebar-item:nth-child(2) { animation-delay: 0.1s; }
.sidebar-item:nth-child(3) { animation-delay: 0.15s; }
.sidebar-item:nth-child(4) { animation-delay: 0.2s; }
.sidebar-item:nth-child(5) { animation-delay: 0.25s; }
.sidebar-item:nth-child(6) { animation-delay: 0.3s; }

/* Card Animations */
.card {
  animation: slideInFromBottom 0.4s ease;
}

/* Tool Card Staggered Animation */
.tool-card {
  animation: slideInFromBottom 0.4s ease;
}

.tool-card:nth-child(1) { animation-delay: 0s; }
.tool-card:nth-child(2) { animation-delay: 0.05s; }
.tool-card:nth-child(3) { animation-delay: 0.1s; }
.tool-card:nth-child(4) { animation-delay: 0.15s; }
.tool-card:nth-child(5) { animation-delay: 0.2s; }
.tool-card:nth-child(6) { animation-delay: 0.25s; }

/* Smooth Page Content Fade */
.page-content {
  animation: fadeIn 0.4s ease;
}
