# ============================================================
# Orbit Server — Environment Configuration
# Copy this file to .env and fill in the values
# ============================================================

# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# PostgreSQL
DATABASE_URL=postgresql://orbit:your_password@localhost:5432/orbit

# JWT
JWT_ACCESS_SECRET=change-me-to-a-random-64-char-string
JWT_REFRESH_SECRET=change-me-to-another-random-64-char-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# Proxy — set to true ONLY when behind Nginx/Caddy (prevents X-Forwarded-For spoofing)
TRUST_PROXY=false

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173

# Rate limiting
RATE_LIMIT_ENABLED=true

# Logging
LOG_LEVEL=info
