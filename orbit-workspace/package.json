{
  "name": "orbit",
  "version": "0.3.0",
  "description": "Orbit - Premium desktop productivity hub for Windows",
  "main": "apps/desktop/electron/main/main.js",
  "author": "Your Name",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "cd apps/desktop/renderer && npx vite",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "build": "npm run version:sync && npm run version:check && npm run build:renderer && npm run build:electron",
    "build:renderer": "cd apps/desktop/renderer && npx vite build",
    "build:electron": "electron-builder",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win",
    "version:sync": "node scripts/sync-version.mjs",
    "version:check": "node scripts/check-version-consistency.mjs",
    "preversion": "npm run version:check",
    "version": "npm run version:sync",
    "postversion": "npm run version:check",
    "release": "npx -y -p semantic-release -p conventional-changelog-conventionalcommits -p @semantic-release/commit-analyzer -p @semantic-release/release-notes-generator -p @semantic-release/changelog -p @semantic-release/exec -p @semantic-release/git -p @semantic-release/github semantic-release",
    "release:dry": "npx -y -p semantic-release -p conventional-changelog-conventionalcommits -p @semantic-release/commit-analyzer -p @semantic-release/release-notes-generator -p @semantic-release/changelog -p @semantic-release/exec -p @semantic-release/git -p @semantic-release/github semantic-release --dry-run --no-ci"
  },
  "dependencies": {
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
    "argon2": "^0.44.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.6.2",
    "crypto-random-string": "^5.0.0",
    "uuid": "^13.0.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^40.0.0",
    "electron-builder": "^24.9.1",
    "electron-rebuild": "^3.2.9",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.orbit.app",
    "productName": "Orbit",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Orbit"
    },
    "files": [
      "apps/desktop/electron/**/*",
      "apps/desktop/renderer/dist/**/*",
      "tools/**/*",
      "data/**/*"
    ]
  }
}
